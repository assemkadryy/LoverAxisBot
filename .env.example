# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram Group/Channel ID (the group members subscribe to)
TELEGRAM_GROUP_ID=-1001234567890

# Bot admin Telegram user ID (your personal Telegram ID)
ADMIN_USER_ID=123456789

# Ziina API Token (get from https://ziina.com/business/connect)
ZIINA_API_TOKEN=your_ziina_api_token

# Currency code (AED, USD, etc.)
CURRENCY_CODE=USD

# Subscription prices (in main currency unit, e.g. 200 = 200 AED)
MONTHLY_PRICE=200
BIWEEKLY_PRICE=140

# Enable Ziina test mode (true/false)
ZIINA_TEST_MODE=true

# Database path (set to /data/subscriptions.db on Railway with a volume)
DATABASE_PATH=subscriptions.db
