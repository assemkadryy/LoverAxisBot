# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_GROUP_ID=-1001234567890
ADMIN_USER_ID=123456789
TELEGRAM_BOT_USERNAME=YourBotUsername

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe amounts in cents (230 USD = 23000, 140 USD = 14000)
MONTHLY_AMOUNT=23000
BIWEEKLY_AMOUNT=14000

# Display
CURRENCY_CODE=USD
MONTHLY_PRICE=230
BIWEEKLY_PRICE=140

# Railway public URL (e.g. https://loveraxisbot-production.up.railway.app)
PUBLIC_URL=https://loveraxisbot-production.up.railway.app

# Database
DATABASE_PATH=subscriptions.db
