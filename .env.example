# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram Group/Channel ID (the group members subscribe to)
TELEGRAM_GROUP_ID=-1001234567890

# Bot admin Telegram user ID (your personal Telegram ID)
ADMIN_USER_ID=123456789

# Stripe fixed payment links
STRIPE_MONTHLY_LINK=https://buy.stripe.com/9B68wP6e39dk7Hg4cndnW02
STRIPE_BIWEEKLY_LINK=https://buy.stripe.com/fZu14n6e3cpw0eOgZ9dnW03

# Currency code and prices (display only)
CURRENCY_CODE=USD
MONTHLY_PRICE=200
BIWEEKLY_PRICE=140

# Database path (set to /data/subscriptions.db on Railway with a volume)
DATABASE_PATH=subscriptions.db
